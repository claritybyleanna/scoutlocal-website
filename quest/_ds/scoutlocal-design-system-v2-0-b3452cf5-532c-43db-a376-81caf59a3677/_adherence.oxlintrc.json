{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/badges/**",
              "components/content/**",
              "components/core/**",
              "components/forms/**",
              "mockups/explore-online/**",
              "ui_kits/app/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono|Outfit))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono, Outfit."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|children|defaultOpen|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: question, children, defaultOpen, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|children|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: kind, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:verified|milspouse|founding)$/]",
        "message": "<Badge> kind must be one of 'verified' | 'milspouse' | 'founding'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|arrow|href|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, arrow, href, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|peach|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'peach' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|hover|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tone, hover, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:paper|soft|sage|invert)$/]",
        "message": "<Card> tone must be one of 'paper' | 'soft' | 'sage' | 'invert'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|as|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:muted|accent|sage)$/]",
        "message": "<Eyebrow> tone must be one of 'muted' | 'accent' | 'sage'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|as|onDark|hint|children|placeholder|type|name|required|style|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, as, onDark, hint, children, placeholder, type, name, required, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|select|textarea)$/]",
        "message": "<Field> as must be one of 'input' | 'select' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListingRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|meta|tag|tagTone|last|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ListingRow> doesn't accept that prop. Declared props: name, meta, tag, tagTone, last, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListingRow'] > JSXAttribute[name.name='tagTone'] > Literal[value!=/^(?:sage|live|muted)$/]",
        "message": "<ListingRow> tagTone must be one of 'sage' | 'live' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LivePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<LivePill> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='LivePill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:sage|rust)$/]",
        "message": "<LivePill> tone must be one of 'sage' | 'rust'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|as|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: children, active, onClick, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|suffix|label|delta|tone|size|style|key|ref|className|style|children)$/]",
        "message": "<Stat> doesn't accept that prop. Declared props: value, suffix, label, delta, tone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:ink|sage|rust)$/]",
        "message": "<Stat> tone must be one of 'ink' | 'sage' | 'rust'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Stat'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<Stat> size must be one of 'lg' | 'sm'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
